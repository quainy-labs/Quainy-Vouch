# Quainy Vouch environment

# Frontend API target used by Vite.
VITE_API_BASE=http://127.0.0.1:8000
VOUCH_FRONTEND_URL=http://127.0.0.1:5173

# Backend runtime.
VOUCH_ENV=development
VOUCH_DATA_BACKEND=postgres
VOUCH_ENABLE_DEV_SEED=false
VOUCH_FIXTURE_MODE=none
DATABASE_URL=postgresql://quainy:quainy_dev_password@postgres:5432/quainy_vouch

# Docker Compose Postgres defaults. Use stronger secrets outside local development.
POSTGRES_DB=quainy_vouch
POSTGRES_USER=quainy
POSTGRES_PASSWORD=quainy_dev_password

# Provider defaults. Use deterministic for tests/dev; set VOUCH_MODEL_PROVIDER=openai with
# OPENAI_API_KEY for live structured model calls.
# Deterministic fixtures are enabled only when VOUCH_FIXTURE_MODE=sample or legacy
# VOUCH_ENABLE_DEV_SEED=true, and are blocked when VOUCH_ENV=production.
VOUCH_MODEL_PROVIDER=deterministic
VOUCH_EMBEDDING_PROVIDER=local_hash
VOUCH_LINKEDIN_PUBLISHING_PROVIDER=local

# Optional live model provider keys. Deterministic mode does not require them.
# Organization AI provider settings should reference backend environment variable names
# such as OPENAI_API_KEY or ACME_OPENAI_API_KEY instead of sending raw secrets to the UI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=
GEMINI_API_KEY=
XAI_API_KEY=
# Use http://host.docker.internal:11434/v1 when the backend runs in Docker
# and Ollama runs on the host machine. Use http://localhost:11434/v1 only
# when the backend runs directly on the host.
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_MODEL=llama3.2:3b
LOCAL_LLM_EMBEDDING_MODEL=embeddinggemma:latest

# Optional future LinkedIn OAuth/live publishing settings. The local adapter does not require them.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_SCOPES=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=
REDDIT_SCOPES=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_SCOPES=
META_OAUTH_VERSION=v20.0
