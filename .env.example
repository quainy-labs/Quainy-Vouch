# Quainy Vouch local environment

# Frontend API target used by Vite.
VITE_API_BASE=http://127.0.0.1:8000

# Backend settings reserved for later provider/database hardening.
QUAINY_ENV=local
QUAINY_DATA_BACKEND=memory
QUAINY_MODEL_PROVIDER=deterministic
QUAINY_EMBEDDING_PROVIDER=local_hash

# Optional future provider keys. The current deterministic MVP does not require them.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
